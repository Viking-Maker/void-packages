# Template file for 'libnoise'
pkgname=libnoise
version=1.0.0
revision=1
build_style=cmake
short_desc="Portable open-source coherent noise-generating library for C++"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="LGPL-2.1-only"
homepage="https://libnoise.sourceforge.net/"
distfiles="${SOURCEFORGE_SITE}/libnoise/libnoisesrc-${version}.zip"
checksum=34ed402f43f30ce5e39812642c9533c11082cd2bc092341c65160f5c743be95b

# Do NOT use wrksrc here; we will handle the directory move manually
# to ensure CMake is always in the same folder as the source code.

post_extract() {
	# 1. If the zip extracted into a 'noise' subfolder, move everything up to the root
	if [ -d "noise" ]; then
		mv noise/* .
	fi

	# 2. Delete Windows-specific code that causes errors on Linux
	rm -rf src/win32 win32

	# 3. Create a robust CMakeLists.txt
	cat <<-'EOF' > CMakeLists.txt
		cmake_minimum_required(VERSION 3.5)
		project(libnoise)

		# Find all C++ files anywhere in the current directory or subfolders
		file(GLOB_RECURSE SOURCES "*.cpp")
		
		# Ensure we have files to build
		if(NOT SOURCES)
			message(FATAL_ERROR "No source files found!")
		endif()

		add_library(noise SHARED ${SOURCES})

		# Set include paths for the compiler
		target_include_directories(noise PUBLIC 
			${CMAKE_CURRENT_SOURCE_DIR}/src
		)

		set_target_properties(noise PROPERTIES SOVERSION 0 VERSION 1.0.0)

		# Install the shared library
		install(TARGETS noise DESTINATION lib)

		# Install headers so they can be found via <noise/noise.h>
		# We install the contents of the 'src' folder into 'include/noise'
		install(DIRECTORY src/ DESTINATION include/noise
			FILES_MATCHING PATTERN "*.h"
		)
	EOF
}

libnoise-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
	}
}
