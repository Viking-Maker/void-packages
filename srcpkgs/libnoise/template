# Template file for 'libnoise'
pkgname=libnoise
version=1.0.0
revision=1
build_style=cmake
short_desc="Portable open-source coherent noise-generating library for C++"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="LGPL-2.1-only"
homepage="https://libnoise.sourceforge.net/"
distfiles="${SOURCEFORGE_SITE}/libnoise/libnoisesrc-${version}.zip"
checksum=34ed402f43f30ce5e39812642c9533c11082cd2bc092341c65160f5c743be95b

post_extract() {
	# The original Makefile is severely broken and unmaintained.
	# We generate a standard CMakeLists.txt to build the shared library safely.
	cat <<-'EOF' > CMakeLists.txt
		cmake_minimum_required(VERSION 3.5)
		project(libnoise)
		file(GLOB_RECURSE SOURCES src/*.cpp)
		add_library(noise SHARED ${SOURCES})
		target_include_directories(noise PUBLIC src)
		set_target_properties(noise PROPERTIES SOVERSION 0 VERSION 1.0.0)
		install(TARGETS noise DESTINATION lib)
		install(DIRECTORY src/ DESTINATION include/noise FILES_MATCHING PATTERN "*.h")
	EOF
}

libnoise-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
	}
}
