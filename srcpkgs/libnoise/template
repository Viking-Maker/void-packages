# Template file for 'libnoise'
pkgname=libnoise
version=1.0.0
revision=1
build_style=cmake
short_desc="Portable open-source coherent noise-generating library for C++"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="LGPL-2.1-only"
homepage="https://libnoise.sourceforge.net/"
distfiles="${SOURCEFORGE_SITE}/libnoise/libnoisesrc-${version}.zip"
checksum=34ed402f43f30ce5e39812642c9533c11082cd2bc092341c65160f5c743be95b

# The zip file contains a folder named 'noise'
wrksrc="noise"

post_extract() {
	# Create a CMakeLists.txt inside the 'noise' folder
	cat <<-'EOF' > CMakeLists.txt
		cmake_minimum_required(VERSION 3.5)
		project(libnoise)

		# Find all .cpp files in src/ but ignore the win32 folder
		file(GLOB_RECURSE SOURCES "src/*.cpp")
		list(FILTER SOURCES EXCLUDE REGEX "win32")

		add_library(noise SHARED ${SOURCES})

		# Header search paths for the build itself
		target_include_directories(noise PUBLIC 
			${CMAKE_CURRENT_SOURCE_DIR}/src
		)

		set_target_properties(noise PROPERTIES SOVERSION 0 VERSION 1.0.0)

		# Install the library to /usr/lib/libnoise.so
		install(TARGETS noise DESTINATION lib)

		# Install headers so they appear as /usr/include/noise/noise.h
		# This is what Findlibnoise.cmake usually looks for.
		file(GLOB HEADERS "src/*.h")
		install(FILES ${HEADERS} DESTINATION include/noise)
		
		# Also install subfolder headers (model/module)
		install(DIRECTORY src/model DESTINATION include/noise)
		install(DIRECTORY src/module DESTINATION include/noise)
	EOF
}

libnoise-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
	}
}
