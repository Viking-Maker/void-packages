# Template file for 'libnoise'
pkgname=libnoise
version=1.0.0
revision=1
build_style=cmake
short_desc="Portable open-source coherent noise-generating library for C++"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="LGPL-2.1-only"
homepage="https://libnoise.sourceforge.net/"
distfiles="${SOURCEFORGE_SITE}/libnoise/libnoisesrc-${version}.zip"
checksum=34ed402f43f30ce5e39812642c9533c11082cd2bc092341c65160f5c743be95b

post_extract() {
	# We generate a CMakeLists.txt that excludes the win32 directory
	cat <<-'EOF' > CMakeLists.txt
		cmake_minimum_required(VERSION 3.5)
		project(libnoise)

		# Find all .cpp files but filter out any that are in a 'win32' path
		file(GLOB_RECURSE ALL_SOURCES "noise/src/*.cpp")
		foreach(source_file ${ALL_SOURCES})
			if(NOT source_file MATCHES "win32")
				list(APPEND SOURCES ${source_file})
			endif()
		endforeach()

		add_library(noise SHARED ${SOURCES})

		# Include paths for the build
		target_include_directories(noise PUBLIC 
			noise/src 
			noise/src/model 
			noise/src/module
		)

		set_target_properties(noise PROPERTIES SOVERSION 0 VERSION 1.0.0)

		# Install the library
		install(TARGETS noise DESTINATION lib)

		# Install the headers into include/noise so OrcaSlicer can find "noise/noise.h"
		install(DIRECTORY noise/src/ DESTINATION include/noise
			FILES_MATCHING PATTERN "*.h"
			PATTERN "win32" EXCLUDE
		)
	EOF
}

libnoise-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision}"
	pkg_install() {
		vmove usr/include
		vmove "usr/lib/*.so"
	}
}
