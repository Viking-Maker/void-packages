# Template file for 'limux-bin'
pkgname=limux
version=0.1.6
revision=1
archs="x86_64"
build_style=fetch
depends="gtk4 libadwaita libwebkitgtk60"
short_desc="GPU-accelerated terminal multiplexer for Linux"
maintainer="Viking Maker <vikingmaker@outlook.com>"
license="MIT"
homepage="https://github.com/am-will/limux"
distfiles="https://github.com/am-will/limux/releases/download/v${version}/limux-${version}-linux-x86_64.tar.gz"
checksum="3a6efd9316aaec34a33f5800cf933d37733e07879a8d7917682c677dc675772d "

do_install() {
	# Create necessary directory structure in $DESTDIR
	vmkdir usr/bin
	vmkdir usr/lib
	vmkdir usr/share/applications
	vmkdir usr/share/icons

	# Copy the main binary
	vcopy limux usr/bin/

	# Copy the required Ghostty library to /usr/lib
	if [ -f "libghostty.so" ]; then
		vcopy libghostty.so usr/lib/
	fi

	# Copy the desktop entry
	if [ -f "limux.desktop" ]; then
		vcopy limux.desktop usr/share/applications/
	fi

	# Copy icons (maintaining folder structure)
	if [ -d "icons" ]; then
		vcopy "icons/*" usr/share/icons/
	fi

	# Handle license via the built-in helper
	if [ -f "LICENSE" ]; then
		vlicense LICENSE
	fi
}
