# Template file for 'orcaslicer'
pkgname=orcaslicer
version=2.3.2
revision=1
build_style=cmake
# Limit cores to prevent GitHub Actions from running out of RAM
make_build_args="-j2"
# We bypass OrcaSlicer's broken search script by providing the exact "Release" path
configure_args="
 -DBAMBU_COMMUNITY=ON
 -DOPENVDB_FIND_MODULE_PATH=/usr/lib/cmake/OpenVDB
 -DLIBNOISE_INCLUDE_DIR=/usr/include/noise
 -DLIBNOISE_LIBRARY_RELEASE=/usr/lib/libnoise.so
 -DwxWidgets_CONFIG_EXECUTABLE=/usr/bin/wx-config-gtk3"
hostmakedepends="autoconf automake cereal cmake extra-cmake-modules eigen gettext git pkg-config libtool ninja texinfo"
makedepends="glew-devel gstreamer1-devel gst-plugins-base1-devel gtk+3-devel libmspack-devel libsecret-devel libspnav-devel openssl-devel eudev-libudev-devel libwebkit2gtk41-devel boost-devel tbb-devel libcurl-devel glfw-devel nlopt-devel openvdb-devel cgal-devel libopencv-devel occt-devel libnoise-devel draco-devel wxWidgets-gtk3-devel"
depends="file wget"
short_desc="G-code generator for 3D printers"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="AGPL-3.0-only"
homepage="https://www.orcaslicer.com/"
distfiles="https://github.com/OrcaSlicer/OrcaSlicer/archive/refs/tags/v${version}.tar.gz"
checksum=2c7eea7b1e3757011f2c9520dc1712d789b9182b5c276aba271bf814172b0a52
wrksrc="OrcaSlicer-${version}"

post_patch() {
	# Boost 1.89/1.90+ removed the boost_system stub library, as it is now header-only.
	vsed -i 's/COMPONENTS system /COMPONENTS /g' CMakeLists.txt

	# Fix GCC 14 strict compilation error with CGAL 5.6+ AABB_tree objects.
	# std::vector reallocation requires a noexcept move constructor, which CGAL lacks.
	# std::deque grows without moving existing elements, bypassing the compiler panic.
	vsed -i 's/std::vector<CGAL::AABB_tree/std::deque<CGAL::AABB_tree/g' src/libslic3r/CutSurface.cpp src/libslic3r/CutSurface.hpp
	vsed -i 's/std::vector< CGAL::AABB_tree/std::deque< CGAL::AABB_tree/g' src/libslic3r/CutSurface.cpp src/libslic3r/CutSurface.hpp
	
	# std::deque does not have a reserve() method, so we safely disable it.
	vsed -i 's/result.reserve(models.size());/\/\/result.reserve(models.size());/g' src/libslic3r/CutSurface.cpp

	# Ensure <deque> is included so the compiler understands the new container.
	vsed -i '1i#include <deque>' src/libslic3r/CutSurface.cpp
	vsed -i '1i#include <deque>' src/libslic3r/CutSurface.hpp
}

post_install() {
	vlicense LICENSE.txt
}
