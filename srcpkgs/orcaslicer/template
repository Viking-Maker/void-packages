# Template file for 'orcaslicer'
pkgname=orcaslicer
version=2.3.2
revision=1
hostmakedepends="autoconf automake cmake extra-cmake-modules gettext git pkg-config libtool ninja m4"
# Using YOUR verified Void package names for the system UI/graphics libraries.
# We removed boost, cgal, openvdb, etc. because the AUR method compiles them locally.
makedepends="glew-devel gstreamer1-devel gst-plugins-base1-devel gtk+3-devel libmspack-devel libsecret-devel libspnav-devel openssl-devel eudev-libudev-devel libwebkit2gtk41-devel libcurl-devel glfw-devel wayland-protocols"
depends="file wget"
short_desc="G-code generator for 3D printers"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="AGPL-3.0-only"
homepage="https://www.orcaslicer.com/"
distfiles="https://github.com/OrcaSlicer/OrcaSlicer/archive/refs/tags/v${version}.tar.gz"
checksum=2c7eea7b1e3757011f2c9520dc1712d789b9182b5c276aba271bf814172b0a52
wrksrc="OrcaSlicer-${version}"

post_patch() {
	# Force OrcaSlicer to use our basic Void system libraries (curl, openssl, etc.)
	# instead of downloading them, while allowing it to download CGAL, OpenVDB, etc.
	vsed -i 's/if(FLATPAK)/if(true)/' deps/CMakeLists.txt
}

do_build() {
	# 1. Compile the bundled dependencies (CGAL 5.2.2, OpenVDB, libnoise, etc.)
	mkdir -p deps/build
	cd deps/build
	cmake .. -G Ninja \
		-DDESTDIR="${wrksrc}/deps/build/destdir" \
		-DDEP_DOWNLOAD_DIR="${wrksrc}/deps/DL_CACHE" \
		-DDEP_WX_GTK3=ON
	ninja -j 2

	# 2. Compile OrcaSlicer using those downloaded, perfectly-compatible dependencies
	cd ${wrksrc}
	mkdir -p build
	cd build
	cmake .. -G Ninja \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_FULL_DATAROOTDIR=/usr/share/ \
		-DCMAKE_PREFIX_PATH="${wrksrc}/deps/build/destdir/usr/local" \
		-DSLIC3R_STATIC=1 \
		-DORCA_TOOLS=1 \
		-DSLIC3R_FHS=1 \
		-DSLIC3R_GTK=3 \
		-DBAMBU_COMMUNITY=ON
	ninja -j 2
}

do_install() {
	cd ${wrksrc}/build
	DESTDIR=${DESTDIR} ninja install
	
	cd ${wrksrc}
	vlicense LICENSE.txt
}
