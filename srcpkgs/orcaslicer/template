# Template file for 'orcaslicer'
pkgname=orcaslicer
version=2.3.2
revision=1
build_style=cmake
# Limit cores to prevent GitHub Actions from running out of RAM
make_build_args="-j2"
# We explicitly tell CMake where to find libnoise and OpenVDB
configure_args="
 -DBAMBU_COMMUNITY=ON
 -DOPENVDB_FIND_MODULE_PATH=/usr/lib/cmake/OpenVDB
 -DLIBNOISE_INCLUDE_DIR=/usr/include/noise
 -DLIBNOISE_LIBRARY=/usr/lib/libnoise.so"
hostmakedepends="autoconf automake cereal cmake extra-cmake-modules eigen gettext git pkg-config libtool ninja texinfo"
makedepends="glew-devel gstreamer1-devel gtk+3-devel libmspack-devel libsecret-devel libspnav-devel 
 openssl-devel eudev-libudev-devel webkit2gtk4.1-devel boost-devel tbb-devel libcurl-devel 
 glfw-devel nlopt-devel openvdb-devel cgal-devel opencv-devel opencascade-devel libnoise-devel"
depends="file wget"
short_desc="G-code generator for 3D printers"
maintainer="Soulful Sailer <soulful.sailer@entropic.pro>"
license="AGPL-3.0-only"
homepage="https://www.orcaslicer.com/"
distfiles="https://github.com/OrcaSlicer/OrcaSlicer/archive/refs/tags/v${version}.tar.gz"
checksum=2c7eea7b1e3757011f2c9520dc1712d789b9182b5c276aba271bf814172b0a52
wrksrc="OrcaSlicer-${version}"

post_patch() {
	# Boost 1.89/1.90+ removed the boost_system stub library, as it is now header-only.
	vsed -i 's/COMPONENTS system /COMPONENTS /g' CMakeLists.txt
}

post_install() {
	vlicense LICENSE.txt
}
